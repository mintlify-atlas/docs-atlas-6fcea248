  "keyFeatures": [
    "Contract definition macros (#[contract], #[contractimpl])",
    "Type conversion with contracttype and custom types",
    "Three-tier storage system (Persistent, Temporary, Instance)",
    "Built-in authentication and authorization",
    "Cryptography support (BLS12-381, BN254)",
    "Event publishing for contract activity",
    "Token standard implementation",
    "Comprehensive testing utilities"
  ],
  "publicApiSurface": [
    "#[contract] - Mark struct as contract",
    "#[contractimpl] - Export contract functions",
    "#[contracttype] - Define custom contract types",
    "#[contracterror] - Define error enums",
    "#[contractevent] - Define events",
    "#[contractimport] - Import external contracts",
    "symbol_short! - Create short symbols",
    "Env - Contract execution environment",
    "Address - Contract and account addresses",
    "Storage - Persistent/Temporary/Instance storage",
    "Vec<T> - Contract vector collection",
    "Map<K, V> - Contract key-value map",
    "Bytes/BytesN<N> - Binary data types",
    "Symbol - Short string identifiers",
    "String - UTF-8 strings",
    "auth - Authorization module",
    "crypto - Cryptographic operations",
    "deploy - Contract deployment",
    "events - Event publishing",
    "ledger - Ledger information",
    "token - Token interface",
    "testutils - Testing utilities"
  ]
}
